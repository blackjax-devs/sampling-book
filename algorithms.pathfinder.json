":1}},"key":"HbGq9mGSOk"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"Vec60wxabs"}],"key":"H3YT5TiC5z"}],"key":"eruZ90Gzjf"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"eEHoanfqfW"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"lBATtUd59o"}],"key":"VAFcL6b0kx"}],"key":"p4Sy33DLoq"}],"key":"YINC1NlhjE"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"dY4iJgjHhX"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"FS0HqIcgfA"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"VvjhEuKYjn"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"Q0jR4Vqe6t"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"qk8Y82brMW"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"wWalrI3w6f"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"RvbVnppYS0"}],"key":"C9hotvICqF"}],"key":"xrqHOlyVCp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"aeHrGEdrWI"},{"type":"outputs","id":"BkYUYHovbYoRT7aDnsVrB","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"tOvfad3JN4"}],"key":"vrn8GLzIif"}],"key":"s0JKrTkw0X"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"cOP4K0RdVG"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"z0ZIQ531SG"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"CVQGJdqHRA"}],"key":"bOwpzkS08y"}],"key":"ECOHjKkybk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"rjqjbFi42x"},{"type":"outputs","id":"trf3k66yG0Uoct3hBZLqL","children":[],"key":"fFKYNwIRgv"}],"key":"pmC9kxnG5Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"DagFF731eP"},{"type":"outputs","id":"F9WXFID96DCy61sFxjqvE","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"ifkjzKEIGz"}],"visibility":"show","key":"Wd0vjbm87u"}],"data":{"tags":[]},"visibility":"show","key":"KAuFuCmQ98"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"S2AFxI21bX"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"A7eCILIxHA"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"oRNKUhZmwx"}],"key":"cQJpCpMjKd"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"text","value":"We can calculate explic