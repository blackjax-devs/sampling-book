start":{"line":203,"column":1},"end":{"line":203,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"key":"G72efgqY5t"}],"key":"Pr8SWLNFvN"}],"key":"HuyrQfHBoI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(1, 2, figsize=(8, 2), sharey=True)\nfor i, axi in enumerate(ax):\n    axi.plot(samples[:, i])\n    axi.set_title(f\"$w_{i}$\")\nplt.show()","visibility":"hide","key":"ccCeqI5kaM"},{"type":"outputs","id":"kkFtUyHalwnDda9xblEGX","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x200 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3495181114b6a59c3c437e234abf9bbe","path":"/sampling-book/build/3495181114b6a59c3c437e234abf9bbe.png"}}},"key":"FnCIAIdZNw"}],"visibility":"show","key":"O1bdw6z2yp"}],"data":{"tags":[]},"visibility":"show","key":"OYHbCUISLF"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"children":[{"type":"text","value":"Please note that pathfinder is implemented as follows:","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"key":"nEAD1TlFz3"}],"key":"eJ3gjwV9Kf"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":217,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"it runs L-BFGS optimization and finds the best approximation in the ","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"pX8owMQWYV"},{"type":"inlineCode","value":"init","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"XmavVLEmwT"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"mhNgxjnhxW"}],"key":"oCxHxpRJaH"}],"key":"S8oHWXs2af"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"gp5KC1Y20d"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"Jxn2Xilfsx"}],"key":"LN690u0Kw8"}],"key":"mG17YuOcvO"}],"key":"VfaqI5fS69"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"P6KlqvMiWw"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"trUhMXS3V2"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"wJOIZVNB6N"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"AlpjDdw6GT"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"rBKxGPEgyk"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"M6PTxS1HER"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"JZaImwYkMY"}],"key":"IuT2YBeZ4K"}],"key":"piMn5S4KRN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"i570oNOdhu"},{"type":"outputs","id":"kjZ5WV77F0ttFZ4L8CRez","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"ZneKOmtfpY"}],"key":"mk057uJTSV"}],"key":"ZENooDzYZG"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"r0XiHOtLyV"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"GSDHbmG1Wh"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"wD3FvLULEx"}],"key":"dx3UB5wbHk"}],"key":"UHmyiBPD7J"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"IgTOMOcQlb"},{"type":"outputs","id":"ZuuB-EDgUO-zyUN3xkV7O","children":[],"key":"LutoDEqh6A"}],"key":"BCVa7iaA4r"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"SwpPCIP6Gv"},{"type":"outputs","id":"10FIC_HQUlaSBJfoTao4C","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"H3N2XWeF0X"}],"visibility":"show","key":"s8dORVLAhP"}],"data":{"tags":[]},"visibility":"show","key":"CMvUW9q8Dn"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"R4XR7oeA1c"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"E8Me006C3b"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"mUIrs0dcvK"}],"key":"WqsxhunvbL"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"text","value":"We can calculate explic