<span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">0</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"vUVjiSoRfT"}],"key":"Masg4g3r2c"}],"key":"WcbcGhw8Yg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = X\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","key":"T6JmnYYCtt"},{"type":"outputs","id":"F57b6rK0VDsYdKMTv_Bcj","children":[],"key":"RrcioLMuS3"}],"key":"txZSX7WdkF"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"Pathfinder: Parallel Quasi-Newton Variational Inference","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"eZOliqraPZ"}],"identifier":"pathfinder-parallel-quasi-newton-variational-inference","label":"Pathfinder: Parallel Quasi-Newton Variational Inference","html_id":"pathfinder-parallel-quasi-newton-variational-inference","implicit":true,"key":"pmHcFw7nNF"},{"type":"paragraph","position":{"start":{"line":113,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Starting from a random initialization, Pathfinder locates normal approximations to the target\ndensity along a quasi-Newton optimization path, with local covariance estimated using the inverse Hessian\nestimates produced by the optimizer. Pathfinder returns draws from the approximation with the lowest\nestimated Kullback-Leibler (KL) divergence to the true posterior.\nThe optimizer is the limited memory BFGS algorithm.","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"DZT9PlOEjM"}],"key":"exAlTjeek2"},{"type":"paragraph","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"To help understand the approximations that pathfinder evaluates during its run, here we plot for each step of the L-BFGS optimizer the approximation of the posterior distribution of the model derived by pathfinder and its ELBO:","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"VzKk5dEJKA"}],"key":"g42GSWhPme"}],"key":"sFPVn3Yu8o"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# L-BFGS can occasionally fail to converge from a bad initialization;\n# retry until the ELBO path is finite.\nstop = 0\nwhile stop == 0:\n    rng_key, init_key, infer_key = jax.random.split(rng_key, 3)\n    w0 = jax.random.multivariate_normal(init_key, 2.0 + jnp.zeros(M), jnp.eye(M))\n    _, info = blackjax.vi.pathfinder.approximate(infer_key, logdensity_fn, w0, ftol=1e-6)\n    path = info.path\n    stop = np.isfinite(path.elbo).mean()","key":"F0ofzu1469"},{"type":"outputs","id":"4c20gOAgIDlvOql6OMJRn","children":[],"key":"AQvbmqGAjU"}],"key":"uRlOJPJu7N"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def ellipse_confidence(mu, cov, ax, c, n_std=2.0):\n    import numpy as np\n\n    lambda_, v = np.linalg.eig(cov)\n    lambda_ = np.sqrt(lambda_)\n    ellipse = Ellipse(\n        xy=(*mu,),\n        width=lambda_[0] * n_std * 2,\n        height=lambda_[1] * n_std * 2,\n        angle=np.degrees(np.arctan2(*v[:, 0][::-1])),\n        facecolor=c,\n        edgecolor=\"b\",\n        alpha=0.1,\n    )\n    return ax.add_artist(ellipse)\n\n\nstep = 0.1\nx_, y_ = jnp.mgrid[-1:3:step, -1:3:step]\npos_ = jnp.dstack((x_, y_))\nlogp_ = jnp.nan_to_num(\n    jax.vmap(logdensity_fn)(pos_.reshape(-1, M)).reshape(pos_.shape[0], pos_.shape[1]),\n    nan=-1e10,\n)\nlevels_ = jnp.percentile(logp_.flatten(), jnp.linspace(60, 100, 10))\n\n\nsteps = (jnp.isfinite(path.elbo)).sum()\nrows = int(jnp.ceil(steps / 3))\nfig, axs = plt.subplots(rows, 3, figsize=(15, 5 * rows), sharex=True, sharey=True)\n\nfor i, ax in zip(range(steps), axs.flatten()):\n\n    ax.contour(x_, y_, logp_, levels=levels_)\n    state = jax.tree.map(lambda x: x[i], path)\n    sample_state, _ = blackjax.vi.pathfinder.sample(rng_key, state, 10_000)\n    position_path = path.position[: i + 1]\n    ax.plot(\n        position_path[:, 0],\n        position_path[:, 1],\n        marker=\"*\",\n        linestyle=\"--\",\n        markersize=10,\n    )\n    mu_i, cov_i = sample_state.mean(0), jnp.cov(sample_state, rowvar=False)\n    ellipse_confidence(mu_i, cov_i, ax, \"r\")\n    ax.set_title(f\"Iteration: {i+1}\\nEstimated ELBO: {state.elbo:.2f}\")\nplt.show()","visibility":"hide","key":"hzzdqXklRg"},{"type":"outputs","id":"oum0JJzDdUjTz6LBIrOXf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1500x3000 with 18 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"400a4eb2b95063db38f54a7c234b741c","path":"/sampling-book/build/400a4eb2b95063db38f54a7c234b741c.png"}}},"key":"wSzLHN16Ek"}],"visibility":"show","key":"pR9l2a7yZ8"}],"data":{"tags":[]},"visibility":"show","key":"roJf38nkqs"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":186,"column":1},"end":{"line":186,"column":1}},"children":[{"type":"text","value":"Pathfinder as a Variational Inference Method","position":{"start":{"line":186,"column":1},"end":{"line":186,"column":1}},"key":"mJ8Dxzdfnn"}],"identifier":"pathfinder-as-a-variational-inference-method","label":"Pathfinder as a Variational Inference Method","html_id":"pathfinder-as-a-variational-inference-method","implicit":true,"key":"afouDpEJ8H"},{"type":"paragraph","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"children":[{"type":"text","value":"Pathfinder can be used as a variational inference method. We first create a pathfinder object ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"IvcHnFAJ23"},{"type":"inlineCode","value":"pf","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"OYcRQFrK2q"},{"type":"text","value":" which contains two functions ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"Yn1DB9bqUd"},{"type":"inlineCode","value":"init","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"lDOhWsFiQZ"},{"type":"text","value":" and ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"AsNM3mUKhq"},{"type":"inlineCode","value":"sample","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"rC4V2Nzdb0"},{"type":"text","value":":","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"AVmVm1Grsu"}],"key":"QOVyYavHYN"}],"key":"GZooalxp89"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pf = blackjax.pathfinder(logdensity_fn)\nrng_key, approx_key = jax.random.split(rng_key)\nstate, _ = pf.init(approx_key, w0, ftol=1e-4)","key":"qCyTJKD5ng"},{"type":"outputs","id":"ti8yc24wqzWx84yOvzLca","children":[],"key":"tjc0lj0f6f"}],"key":"wb099U5q5i"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"We can now get samples from the approximation:","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"Cyh2rRi15s"}],"key":"A1ZrOVB3TX"}],"key":"S7GCkvWfS5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"uBEf82hdFW"},{"type":"outputs","id":"yRQBwBTCtUWIPlRRzbB3y","children":[],"key":"wbCUcG14Vf"}],"key":"eoYeqXLkhX"},{"type":"block","childr