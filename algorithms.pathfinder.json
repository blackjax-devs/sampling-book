":1}},"key":"yudmcZ9A83"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"zloNPYh3bS"}],"key":"BGhYEuHAKI"}],"key":"GSxnzyCTQn"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"sxygplJKFr"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"WgXuqTwQDp"}],"key":"mg6p1vpNWP"}],"key":"gNdDc8r5n9"}],"key":"BFXn7CLGfH"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"FJl2FAHxGM"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"HnLDevSjkI"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"h42GrS1tDt"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"iCCaVHGghe"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"Ak4XNkET1z"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"haEnT0H0yQ"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"zepEJ2FLia"}],"key":"Q62dtQOX2e"}],"key":"u7HqJmQMBi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"iR2slvDJvr"},{"type":"outputs","id":"olWwkwdVJuGcHMsmRP-Cj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"AY8y02M2vU"}],"key":"sbYpnSYLF9"}],"key":"rI7LaMMq7j"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"r3xbggEQxL"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"bdlXIvMUbc"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"hRFFiPz0Tc"}],"key":"smhuQU3EDk"}],"key":"MqJFdRYtVF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"wNLYgTKPlW"},{"type":"outputs","id":"IdYSYrM7nlkrgu5xrfR_N","children":[],"key":"q3dmWM5XGs"}],"key":"JhE0zXVyvP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"g1m7j6DP7J"},{"type":"outputs","id":"sarHCOCY8T5D4l7QVaJW4","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"QrvakZ18zI"}],"visibility":"show","key":"rzERhkCc2a"}],"data":{"tags":[]},"visibility":"show","key":"eVzBtEt3dx"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"qoLbyBptsi"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"dQKys2SrCy"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"KKaZvGhU6Y"}],"key":"LUYPusVP2P"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"text","value":"We can calculate explic