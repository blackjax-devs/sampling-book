":1}},"key":"F8ohRDSQom"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"T04vgr1BKA"}],"key":"un0fijLtOo"}],"key":"mqBJDe7bZz"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"jDRJy1AzxF"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"WipfgELVe3"}],"key":"nf4he714sO"}],"key":"VH9WHaNk5Y"}],"key":"WaQfwtNqwl"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"te6QQiMxFx"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"wfjJK2ABTF"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"CuBDxoTNeu"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"Tts8EvAVyx"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"TyKDHQLzRP"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"HtbQi0n7qr"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"QqjhuyLjgS"}],"key":"Rc03y81SVB"}],"key":"ZrvEhONNKY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"TxkHYPWCFy"},{"type":"outputs","id":"2JJ_bDZC42mE9BF7BTzVn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"B91zBfliz4"}],"key":"KmkCKz36ve"}],"key":"hICrCKTIL6"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"sC33Pbty5v"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"J6DyV4n6Et"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"Uux0FTwbIs"}],"key":"tTJf8rjnMw"}],"key":"nfUUZuRXPh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"gA7jraZ2pY"},{"type":"outputs","id":"7q93HkSrn2qmnMUyby92U","children":[],"key":"IpurMeMIFW"}],"key":"ro3t459ynI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"boYGHxKyD3"},{"type":"outputs","id":"fa-Vk3R_6aV_OTZrvyKJf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"zjNwYpfKd7"}],"visibility":"show","key":"hYrcheV4UC"}],"data":{"tags":[]},"visibility":"show","key":"k36PuNJD4a"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"LSADtRblsm"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"XI8iNIjQYb"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"uLTiVMyfYe"}],"key":"mU0WnLx0nK"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"text","value":"We can calculate explic