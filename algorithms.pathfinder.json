<span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">0</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"MzBcM2KHx4"}],"key":"xsjNg8ReNw"}],"key":"Mrc0VqITTq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = X\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","key":"H1P7t3abu8"},{"type":"outputs","id":"Oxa7jaUpkde7UhZwylHJz","children":[],"key":"ovQBlUxXgN"}],"key":"MmFZnN8U2K"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"Pathfinder: Parallel Quasi-Newton Variational Inference","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"Qyc4M1lUzj"}],"identifier":"pathfinder-parallel-quasi-newton-variational-inference","label":"Pathfinder: Parallel Quasi-Newton Variational Inference","html_id":"pathfinder-parallel-quasi-newton-variational-inference","implicit":true,"key":"xxFl79IsoI"},{"type":"paragraph","position":{"start":{"line":113,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Starting from a random initialization, Pathfinder locates normal approximations to the target\ndensity along a quasi-Newton optimization path, with local covariance estimated using the inverse Hessian\nestimates produced by the optimizer. Pathfinder returns draws from the approximation with the lowest\nestimated Kullback-Leibler (KL) divergence to the true posterior.\nThe optimizer is the limited memory BFGS algorithm.","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"AIbG6HvrZ8"}],"key":"DF73aaxLhS"},{"type":"paragraph","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"To help understand the approximations that pathfinder evaluates during its run, here we plot for each step of the L-BFGS optimizer the approximation of the posterior distribution of the model derived by pathfinder and its ELBO:","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"qKCxl3NGbQ"}],"key":"Auc1CR6k4t"}],"key":"UOlTHOvioc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# L-BFGS can occasionally fail to converge from a bad initialization;\n# retry until the ELBO path is finite.\nstop = 0\nwhile stop == 0:\n    rng_key, init_key, infer_key = jax.random.split(rng_key, 3)\n    w0 = jax.random.multivariate_normal(init_key, 2.0 + jnp.zeros(M), jnp.eye(M))\n    _, info = blackjax.vi.pathfinder.approximate(infer_key, logdensity_fn, w0, ftol=1e-6)\n    path = info.path\n    stop = np.isfinite(path.elbo).mean()","key":"QS9oWZedn9"},{"type":"outputs","id":"lq4FhdFKhuck-4WOYfr4x","children":[],"key":"y1qPtWIDOJ"}],"key":"WWpzDA9hKm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def ellipse_confidence(mu, cov, ax, c, n_std=2.0):\n    import numpy as np\n\n    lambda_, v = np.linalg.eig(cov)\n    lambda_ = np.sqrt(lambda_)\n    ellipse = Ellipse(\n        xy=(*mu,),\n        width=lambda_[0] * n_std * 2,\n        height=lambda_[1] * n_std * 2,\n        angle=np.degrees(np.arctan2(*v[:, 0][::-1])),\n        facecolor=c,\n        edgecolor=\"b\",\n        alpha=0.1,\n    )\n    return ax.add_artist(ellipse)\n\n\nstep = 0.1\nx_, y_ = jnp.mgrid[-1:3:step, -1:3:step]\npos_ = jnp.dstack((x_, y_))\nlogp_ = jnp.nan_to_num(\n    jax.vmap(logdensity_fn)(pos_.reshape(-1, M)).reshape(pos_.shape[0], pos_.shape[1]),\n    nan=-1e10,\n)\nlevels_ = jnp.percentile(logp_.flatten(), jnp.linspace(60, 100, 10))\n\n\nsteps = (jnp.isfinite(path.elbo)).sum()\nrows = int(jnp.ceil(steps / 3))\nfig, axs = plt.subplots(rows, 3, figsize=(15, 5 * rows), sharex=True, sharey=True)\n\nfor i, ax in zip(range(steps), axs.flatten()):\n\n    ax.contour(x_, y_, logp_, levels=levels_)\n    state = jax.tree.map(lambda x: x[i], path)\n    sample_state, _ = blackjax.vi.pathfinder.sample(rng_key, state, 10_000)\n    position_path = path.position[: i + 1]\n    ax.plot(\n        position_path[:, 0],\n        position_path[:, 1],\n        marker=\"*\",\n        linestyle=\"--\",\n        markersize=10,\n    )\n    mu_i, cov_i = sample_state.mean(0), jnp.cov(sample_state, rowvar=False)\n    ellipse_confidence(mu_i, cov_i, ax, \"r\")\n    ax.set_title(f\"Iteration: {i+1}\\nEstimated ELBO: {state.elbo:.2f}\")\nplt.show()","visibility":"hide","key":"Q5OPIQ7qVs"},{"type":"outputs","id":"1wS1N_CS5CMAHHZ8roKIw","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1500x3000 with 18 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"400a4eb2b95063db38f54a7c234b741c","path":"/sampling-book/build/400a4eb2b95063db38f54a7c234b741c.png"}}},"key":"aE9xFpjN4A"}],"visibility":"show","key":"oi4uqX8bwb"}],"data":{"tags":[]},"visibility":"show","key":"V0MnlYul4g"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":186,"column":1},"end":{"line":186,"column":1}},"children":[{"type":"text","value":"Pathfinder as a Variational Inference Method","position":{"start":{"line":186,"column":1},"end":{"line":186,"column":1}},"key":"NY5TnPJheb"}],"identifier":"pathfinder-as-a-variational-inference-method","label":"Pathfinder as a Variational Inference Method","html_id":"pathfinder-as-a-variational-inference-method","implicit":true,"key":"rGahyvxi3j"},{"type":"paragraph","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"children":[{"type":"text","value":"Pathfinder can be used as a variational inference method. We first create a pathfinder object ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"MMoEpt5hU6"},{"type":"inlineCode","value":"pf","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"DF2WSU07lL"},{"type":"text","value":" which contains two functions ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"tOTGGtc0Lh"},{"type":"inlineCode","value":"init","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"facopc5tf0"},{"type":"text","value":" and ","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"WMhbXtxOCO"},{"type":"inlineCode","value":"sample","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"tg8kQHRvNk"},{"type":"text","value":":","position":{"start":{"line":188,"column":1},"end":{"line":188,"column":1}},"key":"yWbaQIVvOJ"}],"key":"ljTPFVryJQ"}],"key":"vJQwAWlMt6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pf = blackjax.pathfinder(logdensity_fn)\nrng_key, approx_key = jax.random.split(rng_key)\nstate, _ = pf.init(approx_key, w0, ftol=1e-4)","key":"HxgwpDWNXi"},{"type":"outputs","id":"AABXXMeW0lJLpuUKDzh3z","children":[],"key":"nspF19TaQJ"}],"key":"QOTPrelpOZ"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"children":[{"type":"text","value":"We can now get samples from the approximation:","position":{"start":{"line":196,"column":1},"end":{"line":196,"column":1}},"key":"fYGDp0f8eE"}],"key":"VNa2UUtfqi"}],"key":"CznogxGJPj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"DvKqkAL2qb"},{"type":"outputs","id":"mxYCjVW9xYgnQEftqJ24c","children":[],"key":"VQwttsDkzJ"}],"key":"zH6YsM1RVd"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"key":"qQdZNGYihM"}],"key":"wApqyOTqVX"}],"key":"SNLXAd4ZXW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(1, 2, figsize=(8, 2), sharey=True)\nfor i, axi in enumerate(ax):\n    axi.plot(samples[:, i])\n    axi.set_title(f\"$w_{i}$\")\nplt.show()","visibility":"hide","key":"IJ5fw6x3ql"},{"type":"outputs","id":"Gu0EmrR977gJc0wnlFNbi","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x200 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3495181114b6a59c3c437e234abf9bbe","path":"/sampling-book/build/3495181114b6a59c3c437e234abf9bbe.png"}}},"key":"kppdj3O5ny"}],"visibility":"show","key":"kQJpZzuWZe"}],"data":{"tags":[]},"visibility":"show","key":"PmSZ9Z3dw5"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"children":[{"type":"text","value":"Please note that pathfinder is implemented as follows:","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"key":"zh7AzpA4kr"}],"key":"lcqKUFMMyQ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":217,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"it runs L-BFGS optimization and finds the best approximation in the ","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"HWMnTeWTdI"},{"type":"inlineCode","value":"init","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"P8l8EUmGCg"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"QzKezsJvAY"}],"key":"wGzGi6Dmvh"}],"key":"Cwun5GFygF"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"PBAtpx7Lq2"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"isvC2Jmc1O"}],"key":"n9SdU4EUP2"}],"key":"LGfum3nilJ"}],"key":"Oi6v7iwxM5"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"PLIim1frpc"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"qEDIILc216"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"ev6mrMCLZW"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"nPGp2JpTqW"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"KzdjU9jU14"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"ZDlB7HUg5g"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"VUP2Riqo9q"}],"key":"NEOqXKwy3K"}],"key":"zlW712gmvo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"D9EOEk1OKb"},{"type":"outputs","id":"qKVecJpNP8F3afFucvkks","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"oVC4kx0HMc"}],"key":"wahl29XP7C"}],"key":"gx7RKeBDiH"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"cWD1robFWL"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"Cu1lmi8RBd"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"sBWJn5ii1S"}],"key":"Cc7L7w187p"}],"key":"bS6TMhJEwM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"eIuV1KUXPy"},{"type":"outputs","id":"edW5dwzqXIEJ9djJvixlw","children":[],"key":"y7B9tPTv2m"}],"key":"CLIIVxzTgE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"tmDxoV3V0h"},{"type":"outputs","id":"StpsjAKtrdKt_OYVuvobD","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"JQRZCrdQVO"}],"visibility":"show","key":"sBescVInQK"}],"data":{"tags":[]},"visibility":"show","key":"oj0eAq4kKU"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"fPvVD3FTGL"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"df4mMTzooK"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"YWKFf1B3x4"}],"key":"jrPqMIMOGS"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"