start":{"line":203,"column":1},"end":{"line":203,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":203,"column":1},"end":{"line":203,"column":1}},"key":"dP4zL8RXLq"}],"key":"jvCLlltc2n"}],"key":"y8AmpPHLRh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(1, 2, figsize=(8, 2), sharey=True)\nfor i, axi in enumerate(ax):\n    axi.plot(samples[:, i])\n    axi.set_title(f\"$w_{i}$\")\nplt.show()","visibility":"hide","key":"xEhhTX4Ns5"},{"type":"outputs","id":"jPSJ5Yj5pUZJmLfVwFsM_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x200 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3495181114b6a59c3c437e234abf9bbe","path":"/sampling-book/build/3495181114b6a59c3c437e234abf9bbe.png"}}},"key":"CVkxNzRgQ9"}],"visibility":"show","key":"lHq2i5FcL5"}],"data":{"tags":[]},"visibility":"show","key":"QRjTtsSZG2"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"children":[{"type":"text","value":"Please note that pathfinder is implemented as follows:","position":{"start":{"line":215,"column":1},"end":{"line":215,"column":1}},"key":"zXO6BPgFCH"}],"key":"fEuHllgzeJ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":217,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"it runs L-BFGS optimization and finds the best approximation in the ","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"lD5xVY6gSH"},{"type":"inlineCode","value":"init","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"q7JkownZkz"},{"type":"text","value":" phase","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"wKc3vWVpYl"}],"key":"N5d6ob1JIA"}],"key":"plC6Su8hnm"},{"type":"listItem","spread":true,"position":{"start":{"line":218,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"step","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"zPf4jWynWa"},{"type":"text","value":" phase it’s just sampling from a multinormal distribution, whose parameters have been already estimated","position":{"start":{"line":218,"column":1},"end":{"line":218,"column":1}},"key":"XeqxvOjZFU"}],"key":"exmWQ0u7jL"}],"key":"umVmeGHb2E"}],"key":"cwMbofsciH"},{"type":"paragraph","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"children":[{"type":"text","value":"Hence it makes sense to ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"xwJeqlfqWC"},{"type":"inlineCode","value":"jit","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"dBA3rTvoZX"},{"type":"text","value":" the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"OMFxlsEFIN"},{"type":"inlineCode","value":"init","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"iOH410N5Wz"},{"type":"text","value":" function and then use the ","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"DTY7gVUFQl"},{"type":"inlineCode","value":"sample","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"dNWruq6vHI"},{"type":"text","value":" helper function in the pathfinder object instead of implementing the inference loop:","position":{"start":{"line":220,"column":1},"end":{"line":220,"column":1}},"key":"lp87Uwi2bb"}],"key":"QJED8HEjIw"}],"key":"jfG72jDTXe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"%%time\n\nstate, _ = jax.jit(pf.init)(approx_key, w0)\nsamples, _ = pf.sample(sample_key, state, 5_000)","key":"iHHz3KEDyO"},{"type":"outputs","id":"Fqy_yz0KUAuPHKWXmR6C6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"CPU times: user 6.02 s, sys: 98.3 ms, total: 6.12 s\nWall time: 3.24 s\n"},"key":"u6qZxG4NZ2"}],"key":"iuWhddNKrP"}],"key":"Y00rvEBGV2"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"children":[{"type":"text","value":"Quick comparison against the Rosenbluth-Metropolis-Hastings kernel ","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"OKtZIS9z80"},{"type":"inlineCode","value":"rmh","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"d7DhF0LWtp"},{"type":"text","value":":","position":{"start":{"line":229,"column":1},"end":{"line":229,"column":1}},"key":"UQjD4ofgVb"}],"key":"CqS5UXtytK"}],"key":"SrD2Qv8lDG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, info = kernel(rng_key, state)\n        return state, (state, info)\n\n    keys = jax.random.split(rng_key, num_samples)\n    return jax.lax.scan(one_step, initial_state, keys)\n\n\nrmh = blackjax.rmh(\n    logdensity_fn, blackjax.mcmc.random_walk.normal(sigma=jnp.ones(M) * 0.7)\n)\nstate_rmh = rmh.init(w0)\nrng_key, sample_key = jax.random.split(rng_key)\n_, (samples_rmh, _) = inference_loop(sample_key, rmh.step, state_rmh, 5_000)","key":"yv4qHmw6XE"},{"type":"outputs","id":"NWBK3MEyqKRhbeKnEG4fM","children":[],"key":"Y7Xd6hD7Rt"}],"key":"Fi7VJkVxwW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(2, 2, figsize=(10, 4), sharey=True)\nfor i in range(2):\n    ax[i, 0].plot(samples_rmh.position[:, i])\n    ax[i, 0].axvline(x=300, c=\"tab:red\")\n    ax[i, 0].set_ylabel(f\"$w_{i}$\")\n    ax[i, 1].plot(samples[:, i])\n\nax[0, 0].set_title(\"RMH\")\nax[0, 1].set_title(\"Pathfinder\")\nfig.show()","visibility":"hide","key":"UEPEtyOG0L"},{"type":"outputs","id":"sZeg_0BEjExV-uqZCJIB_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1e19e3b418a02e1bc0bb411eb9c07e08","path":"/sampling-book/build/1e19e3b418a02e1bc0bb411eb9c07e08.png"}}},"key":"f0Pj9gExB8"}],"visibility":"show","key":"lyyWttjIv8"}],"data":{"tags":[]},"visibility":"show","key":"ntI1UdG1Ml"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Pathfinder as an Initialization Tool for MCMC Kernels","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"NNgk58gI3b"}],"identifier":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","label":"Pathfinder as an Initialization Tool for MCMC Kernels","html_id":"pathfinder-as-an-initialization-tool-for-mcmc-kernels","implicit":true,"key":"WvBZjnEXz5"},{"type":"paragraph","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"children":[{"type":"text","value":"Pathfinder uses internally the inverse hessian estimation of the L-BFGS optimizer to evaluate the approximations to the target distribution along the quasi-Newton optimization path.","position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},"key":"MWRvOoK3jH"}],"key":"tF9wiYUXfB"},{"type":"paragraph","position":{"start":{"line":269,"column":1},"end":{"line":269,"column":1}},"children":[{"type":"text","value":"We can calculate explic