term.sum()","visibility":"show","key":"MRwScbzcBK"},{"type":"outputs","id":"COxKRkVsiRK7W1fI0aZsE","children":[],"visibility":"show","key":"za4Glggnhz"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"IB639IG8cv"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"Posterior sampling","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"k8w53JwMVO"}],"identifier":"posterior-sampling","label":"Posterior sampling","html_id":"posterior-sampling","implicit":true,"key":"qPdAOohVwW"},{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"ccjLYZCNaa"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"pgW5jIqwyI"},{"type":"text","value":"’s Latent Gaussian sampler to sample from the posterior distribution.","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"m6zQotasNm"}],"key":"yM5DvoWGZR"}],"key":"YapFwAngON"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from blackjax.mcmc.marginal_latent_gaussian import (\n    init,\n    build_kernel,\n    svd_from_covariance,\n)\n\ncov_svd = svd_from_covariance(C)\nU, Gamma, U_t = cov_svd","key":"oIiUhZMhCz"},{"type":"outputs","id":"t66vPMAyf6iuGMvlzr6hT","children":[],"key":"MDZI5YFyRf"}],"key":"jMos2Sp7oF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"w0 = jnp.zeros((M,))\n\ninit_fn = lambda x: init(x, log_likelihood, U_t)\ninitial_state = init_fn(w0)\n\nkernel = build_kernel(cov_svd)\nstep = lambda k, x, delta: kernel(k, x, log_likelihood, delta)","key":"aBxOIMUEme"},{"type":"outputs","id":"OikZqNi8FRNvFUUJl3F-a","children":[],"key":"G79JZLl1vd"}],"key":"Cs1taSYrFG"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"We first define a calibration loop. The goal is to find the “step-size” ","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"Qbu09ihH6L"},{"type":"inlineCode","value":"delta","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"H2r0Rrdibt"},{"type":"text","value":" that approximately corresponds to an acceptance probability of 0.5.","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"KCeVJOpEkS"}],"key":"raOksf6E4Y"}],"key":"njCQKwQIMJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def calibration_loop(\n    rng_key,\n    initial_state,\n    initial_delta,\n    num_steps,\n    update_every=100,\n    target=0.5,\n    rate=0.5,\n):\n    def body(carry):\n        i, state, delta, pct_accepted, rng_key = carry\n        rng_key, rng_key2 = jax.random.split(rng_key, 2)\n        state, info = step(rng_key, state, delta)\n\n        # restart calibration of delta\n        j = i % update_every\n        pct_accepted = (j * pct_accepted + info.is_accepted) / (j + 1)\n        diff = target - pct_accepted\n        delta = jax.lax.cond(\n            j == 0, lambda _: delta * (1 - diff * rate), lambda _: delta, None\n        )\n\n        return i + 1, state, delta, pct_accepted, rng_key2\n\n    _, final_state, final_delta, final_pct_accepted, _ = jax.lax.while_loop(\n        lambda carry: carry[0] < num_steps,\n        body,\n        (0, initial_state, initial_delta, 0.0, rng_key),\n    )\n\n    return final_state, final_delta\n\n\ndef inference_loop(rng_key, initial_delta, initial_state, num_samples, num_burnin):\n    rng_key, rng_key2 = jax.random.split(rng_key, 2)\n\n    initial_state, delta = calibration_loop(\n        rng_key, initial_state, initial_delta, num_burnin\n    )\n\n    @jax.jit\n    def one_step(carry, rng_key):\n        i, pct_accepted, state = carry\n        state, info = step(rng_key, state, delta)\n        pct_accepted = (i * pct_accepted + info.is_accepted) / (i + 1)\n        return (i + 1, pct_accepted, state), state\n\n    keys = jax.random.split(rng_key, num_samples)\n    (_, tota_pct_accepted, _), states = jax.lax.scan(\n        one_step, (0, 0.0, initial_state), keys\n    )\n    return states, tota_pct_accepted","key":"r00UdHXiuH"},{"type":"outputs","id":"dcrExzBhhzlE33IP5J-cy","children":[],"key":"kmN6slnaPu"}],"key":"NcpDjI5Q8V"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":197,"column":1},"end":{"line":197,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":197,"column":1},"end":{"line":197,"column":1}},"key":"KWvOxYUtqT"}],"key":"J4hGVjbFes"}],"key":"qtAGrxNBPT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates, tota_pct_accepted = inference_loop(sample_key, 0.5, initial_state, 5_000, 1_000)\nprint(f\"Percentage of accepted samples (after calibration): {tota_pct_accepted:.2%}\")","key":"lfKmeUQjSp"},{"type":"outputs","id":"b9tF7b708Efeusju7Dg7n","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Percentage of accepted samples (after calibration): 63.88%\n"},"key":"eTfIgUlkeb"}],"key":"PirOLOnpdv"}],"key":"sQXmOLOG9y"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"key":"LYaPVUD2wK"}],"key":"HsEXTk2a9G"}],"key":"yDubIQacO9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\nplt.show()","visibility":"hide","key":"qPJhfc4YRI"},{"type":"outputs","id":"3oHYbx5cB_TrL8wd5Edsj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x200 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"eb9978c2fb9fd45060bb821afa4d7def","path":"/sampling-book/build/eb9978c2fb9fd45060bb821afa4d7def.png"}}},"key":"B2YYwBN6CV"}],"visibility":"show","key":"upPMfMvh7j"}],"data":{"tags":[]},"visibility":"show","key":"MQQd6tDk2p"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"chains = states.position\nnsamp, _ = chains.shape","key":"QRHCnXVPV4"},{"type":"outputs","id":"oO9jfKHxauM4TYJeg0HPF","children":[],"key":"c0JbFeJ3sY"}],"key":"kN1VxkgKle"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":222,"column":1},"end":{"line":222,"column":1}},"children":[{"type":"text","value":"Predictive distribution","position":{"start":{"line":222,"column":1},"end":{"line":222,"column":1}},"key":"LPDr60Gzuy"}],"identifier":"predictive-distribution","label":"Predictive distribution","html_id":"predictive-distribution","implicit":true,"key":"cZmOBM2D09"},{"type":"paragraph","position":{"start":{"line":224,"column":1},"end":{"line":224,"column":1}},"children":[{"type":"text","value":"Having infered the posterior distribution of the regression’s coefficients we can compute the probability to belong to the first cluster at each position ","position":{"start":{"line":224,"column":1},"end":{"line":224,"column":1}},"key":"sd8gZfYsH7"},{"type":"inlineMath","value":"(X_0, X_1)","position":{"start":{"line":224,"column":1},"end":{"line":224,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><msub><mi>X</mi><mn>0</mn></msub><mo separator=\"true\">,</mo><msub><mi>X</mi><mn>1</mn></msub><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">(X_0, X_1)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">(</span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3011em;\"><span style=\"top:-2.55em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">0</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3011em;\"><span style=\"top:-2.55em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mclose\">)</span></span></span></span>","key":"tBkRzLoke8"},{"type":"text","value":".","position":{"start":{"line":224,"column":1},"end":{"line":224,"column":1}},"key":"gR7gUG2m9j"}],"key":"AcmMtzZ0dt"}],"key":"P9i7MU1Nny"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a meshgrid\nxmin, ymin = X.min(axis=0) - 0.1\nxmax, ymax = X.max(axis=0) + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"vo6cpQuW2Z"},{"type":"outputs","id":"q056vMSZkLWRvQjmY8aEp","children":[],"key":"iS8QERFNzO"}],"key":"qMNRlEyS9C"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\")\nplt.show()","visibility":"hide","key":"bbc1vC9uaa"},{"type":"outputs","id":"uF2QdgFjBqQZbBtawMGPk","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"dcc69dc9d9d534f1c0c2e4b8db5ab7b2","path":"/sampling-book/build/dcc69dc9d9d534f1c0c2e4b8db5ab7b2.png"}}},"key":"uViBRyc8kF"}],"visibility":"show","key":"oloNmPEClQ"}],"data":{"tags":[]},"visibility":"show","key":"dLGqwrYpxs"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":250,"column":1},"end":{"line":250,"column":1}},"children":[{"type":"text","value":"We essentially recover the same contours as with the standard random walk approach.","position":{"start":{"line":250,"column":1},"end":{"line":250,"column":1}},"key":"BFlSDgCOx4"}],"key":"iyyntrhkFu"}],"key":"lquBCMLq2V"}],"key":"a9idcbvVHd"},"references":{"cite":{"order":[],"dat