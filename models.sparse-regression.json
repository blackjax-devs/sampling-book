s[i]\n    ax.plot(samples.position[\"log_lmbda\"][...,i],\n            samples.position[\"beta\"][...,i],\n            'o', ms=.4, alpha=.75)\n    ax.set(\n        xlabel=rf\"$\\lambda$[{i}]\",\n        ylabel=rf\"$\\beta$[{i}]\",\n    )\nfor j in range(i+1, n_col*n_row):\n    axes[j].remove()\nplt.tight_layout();","key":"F2qiR7PC4j"},{"type":"outputs","id":"uh7tUjpi8BCg4z72ULBDV","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x1400 with 25 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"d5458fda33dfb36608fd72802bdb27db","path":"/sampling-book/build/d5458fda33dfb36608fd72802bdb27db.png"}}},"key":"V0b7vt3Qhx"}],"key":"c8Q3xkkPaE"}],"key":"C8CQlnZoRf"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"children":[{"type":"text","value":"While some parameters (for instance the 15th) exhibit no particular correlations, the funnel geometry can still be observed for a few of them (4th, 13th, etc.). Ideally one would adopt a centered parametrization for those parameters to get a better approximation to the true posterior distribution, but here we also assess the ability of the sampler to explore these funnel geometries.","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"wRbf6XKiUc"}],"key":"sHjw6jCKVp"}],"key":"PbNnM5YZDs"},{"type":"block","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"children":[{"type":"text","value":"We can convince ourselves that the Horseshoe prior induces sparsity on the regression coefficients by looking at their posterior distribution:","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"key":"Wc5qEfrOzm"}],"key":"vQIBAccvve"}],"key":"HoQokv4o7Q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"_, axes = plt.subplots(n_row, n_col, sharex=True, figsize=(n_col * 3, n_row * 2))\naxes = axes.flatten()\nfor i in range(n_pred):\n    ax = axes[i]\n    ax.hist(samples.position[\"beta\"][..., i],\n            bins=50, density=True, histtype=\"step\")\n    ax.set_xlabel(rf\"$\\beta$[{i}]\")\n    ax.get_yaxis().set_visible(False)\n    ax.spines[\"left\"].set_visible(False)\nax.set_xlim([-2, 2])\nfor j in range(i+1, n_col*n_row):\n    axes[j].remove()\nplt.tight_layout();","key":"WBxhJ95fdW"},{"type":"outputs","id":"G_puTi4-oPG9pBdsMK2_A","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x1400 with 25 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"2612b01c0aaaa209ad152b545657667b","path":"/sampling-book/build/2612b01c0aaaa209ad152b545657667b.png"}}},"key":"wpdi8PwJPJ"}],"key":"W8PDsBYl5a"}],"key":"AAkhWlCqAL"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"children":[{"type":"text","value":"Indeed, many of the parameters are centered around ","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"key":"s4fuyQCOFm"},{"type":"text","value":"0","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"key":"gBTpFGpbNU"},{"type":"text","value":".","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"key":"PterOd22M3"}],"key":"Iu0W7w9hWL"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"nbba2I30qB"}],"key":"rbtYihLAxQ"},{"type":"paragraph","position":{"start":{"line":242,"column":1},"end":{"line":242,"column":1}},"children":[{"type":"text","value":"It is interesting to notice that the interactions for the parameters with large values do not exhibit funnel geometries.","position":{"start":{"line":242,"column":1},"end":{"line":242,"column":1}},"key":"BkRSQRUI5I"}],"key":"venKA0idEc"}],"key":"fMnPm57H1J"}],"key":"VXMeWxaNNY"},{"type":"block","position":{"start":{"line":245,"column":1},"end":{"line":245,"column":1}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":247,"column":1},"end":{"line":247,"column":1}},"children":[{"type":"text","value":"Bibliography","position":{"start":{"line":247,"column":1},"end":{"line":247,"column":1}},"key":"EercJFyKWc"}],"identifier":"bibliography","label":"Bibliography","html_id":"bibliography","implicit":true,"key":"pHNHjHLUeC"},{"type":"bibliography","filter":"docname in docnames","key":"n3iZwnrWoW"}],"key":"RvgrXg7QHr"}],"key":"JLkkz73HiL"},"references":{"cite":{"order":["carvalho2010horseshoe","papaspiliopoulos2007general","dua2017machine","hoffman2022tuning"],"data":{"carvalho2010horseshoe":{"label":"carvalho2010horseshoe","enumerator":"1","html":"Carvalho, C. M., Polson, N. G., & Scott, J. G. (2010). The horseshoe estimator for sparse signals. <i>Biometrika</i>, <i>97</i>(2), 465–480."},"papaspiliopoulos2007general":{"label":"papaspiliopoulos2007general","enumerator":"2","html":"Papaspiliopoulos, O., Roberts, G. O., & Sköld, M. (2007). A general framework for the parametrization of hierarchical models. <i>Statistical Science</i>, 59–73."},"dua2017machine":{"label":"dua2017machine","enumerator":"3","html":"Dua, D., & Graff, C. (2017). <i>UCI Machine Learning Repository</i>. University of California, Irvine, School of Information. <a target=\"_blank\" rel=\"noreferrer\" href=\"http://archive.ics.uci.edu/ml\">http://archive.ics.uci.edu/ml</a>","url":"http://archive.ics.uci.edu/ml"},"hoffman2022tuning":{"label":"hoffman2022tuning","enumerator":"4","html":"Hoffman, M. D., & Sountsov, P. (2022). Tuning-Free Generalized Hamiltonian Monte Carlo. <i>International Conference on Artificial Intelligence and Statistics</i>, 7799–7813."}}}},"f