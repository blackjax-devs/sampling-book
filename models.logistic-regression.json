 + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"B98rNmEqV4"},{"type":"outputs","id":"lxxLFXHfbWDReW-XEFkSR","children":[],"key":"pZpK5Bs92b"}],"key":"xfT7St0FkD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\");","visibility":"hide","key":"tQguLm5ak2"},{"type":"outputs","id":"yCLYhHcVab9bA7n5wSX-a","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"6bfe058089219d1da6c17887c33ee87f","path":"/sampling-book/build/6bfe058089219d1da6c17887c33ee87f.png"}}},"key":"gpEHL2sOay"}],"visibility":"show","key":"NduZo1a2Sa"}],"data":{"tags":[]},"visibility":"show","key":"B2UZkxfodv"}],"key":"lUzUC8qPRk"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Sparse regression","url":"/models/sparse-regression","group":"Models"},"next":{"title":"Bayesian Logistic Regression With Latent Gaussian Sampler","url":"/models/logisticregressionwithlatentgaussiansampler","group":"Models"}}},"domain":"http://localhost:3000"}