 + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"jXVgGXKM5i"},{"type":"outputs","id":"tFH1wl83zDXUt1zezAVaC","children":[],"key":"IAzw9v9cWo"}],"key":"rWXyUm4isO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\");","visibility":"hide","key":"WZSpCn6HJH"},{"type":"outputs","id":"VtrXT9QuvTOsNy_2mjP_Y","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b6e4dc34abe8e37016543c9d13eba550","path":"/sampling-book/build/b6e4dc34abe8e37016543c9d13eba550.png"}}},"key":"TmFixcDlkF"}],"visibility":"show","key":"lR20PGd1Bd"}],"data":{"tags":[]},"visibility":"show","key":"C8J3korhnX"}],"key":"qSImuIe4LH"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Sparse regression","url":"/models/sparse-regression","group":"Models"},"next":{"title":"Bayesian Logistic Regression With Latent Gaussian Sampler","url":"/models/logisticregressionwithlatentgaussiansampler","group":"Models"}}},"domain":"http://localhost:3000"}