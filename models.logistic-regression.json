/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"b3V5EY6c7l"}],"key":"CGlKH2vYM2"}],"key":"chMLFY4HRw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"KHbPORqQeW"},{"type":"outputs","id":"Lgm7j67PSeXdsmyDI0vGB","children":[],"visibility":"show","key":"Rs1F63DO8G"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"dlKvV5tSkg"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"qX8ViQyKJi"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"d9y8S0YXFl"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"szOEHRERiT"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"M53IpyJMyL"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"ssB4Iou1oT"}],"key":"yIMDKDtRVf"}],"key":"mlZd29ogsk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"vmFkUUqz7l"},{"type":"outputs","id":"iQfs4oxao0AxGfgzk1mZA","children":[],"key":"Njw2B2NfLD"}],"key":"WguhcdPxEX"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"K06fx0b8Jr"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"agmvHGdDLF"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"FJH7YWeoaK"}],"key":"I4eEwoO0Cn"}],"key":"ekGoNVMKYV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"EBZOVTpEky"},{"type":"outputs","id":"D5ihrej5LHJ9ePikrqY2C","children":[],"key":"xyK10CcH7x"}],"key":"JdVqp9Xwwh"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"Cl5fUtf5F2"}],"key":"li8cOmJBSx"}],"key":"CV2edEdJRr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"VBHeFPOKpA"},{"type":"outputs","id":"m3koHbJm6pqinGUOMcF6u","children":[],"key":"ShqXjA6wKn"}],"key":"obngEBACN4"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"TIcw0fANoX"}],"key":"PrloQTd79h"}],"key":"igrqN2iNNO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"WyYSSP8EuQ"},{"type":"outputs","id":"hgNhC6DfWIkAjHQwxHmrE","children":[{