/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"SAAyIKDHp9"}],"key":"iZHXVWLBJw"}],"key":"IFOOJWTist"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"yR5Y6aEOfQ"},{"type":"outputs","id":"TOrfgI4JOYvDKlLSrZgi_","children":[],"visibility":"show","key":"fwA6uYYwRo"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"HXCZzVZkjB"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"XiiouTEN5s"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"JMmQmClXbI"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"jG2ifcwBKI"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"SszStDi5bf"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"TdLQUAu5qM"}],"key":"xXa99MkbFR"}],"key":"X3Z1OG6U7y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"CW10wQyfrV"},{"type":"outputs","id":"Tgz8w8yCh0lF7HLB4f8VE","children":[],"key":"bio4Q04V0N"}],"key":"HkEaXv4Rqv"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"bfGwBr1npU"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"A6aPCb26xK"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"U0vHzZLl7K"}],"key":"N0IoKGjxkg"}],"key":"FwmPzDq5uN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"aLg0ARQYsI"},{"type":"outputs","id":"UC7Q82X_yv7A94CZuW5UI","children":[],"key":"Y6gqs4fJ4L"}],"key":"W93cxdmXyf"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"zmERLrVW5P"}],"key":"jwIha5M15O"}],"key":"slSeZ2DSEg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"Bkr34o3dpI"},{"type":"outputs","id":"2_WDHdSkjuifZ1oJ5PSB-","children":[],"key":"MwzmWWt4IZ"}],"key":"bo11pa08Ga"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"W5fPmbC7ZU"}],"key":"arANhMzdeS"}],"key":"HkYNSeyQ1a"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"SbRF5kdBy1"},{"type":"outputs","id":"yxDIumueda9aeBoBLsKaF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x200 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"2c068b19de9cf76fca68ecbda205a5ac","path":"/sampling-book/build/2c068b19de9cf76fca68ecbda205a5ac.png"}}},"key":"jn5Revtflp"}],"visibility":"show","key":"wmVzhHsZSQ"}],"data":{"tags":[]},"visibility":"show","key":"xw06DYiSms"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\nchains = states.position[burnin:, :]\nnsamp, _ = chains.shape","key":"v9JVeZCYbH"},{"type":"outputs","id":"uQHN63AIRbaY-LgdlDnJZ","children":[],"key":"OfXjfq5eSD"}],"key":"LXILZsTG7h"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"children":[{"type":"text","value":"Predictive Distribution","position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"key":"xuF9zflyHp"}],"identifier":"predictive-distribution","label":"Predictive Distribution","html_id":"predictive-distribution","implicit":true,"key":"TRKJt3N3Pd"},{"type":"paragraph","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"children":[{"type":"text","value":"Having infered the posterior distribution of the regression’s coefficients we can compute the probability to belong to the first cluster at each position ","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"PkWqaKBfJO"},{"type":"inlineMath","value":"(X_0, X_1)","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><msub><mi>X</mi><mn>0</mn></msub><mo separator=\"true\">,</mo><msub><mi>X</mi><mn>1</mn></msub><mo stretchy=\"false\">)</mo></mrow><annotation e