/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"X5VMx3YBuP"}],"key":"VDWMzGcUDk"}],"key":"PG5KmlYNMb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"PvMuZGtrD2"},{"type":"outputs","id":"pdihVQb-okjgwtUqmlhpJ","children":[],"visibility":"show","key":"hX1WNiI1du"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"SRC50SxG4g"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"EqvgOG0p9i"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"SD6G577tpT"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"kKPLKOVLlP"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"yRNRkXzK8U"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"jy9yFESoZ0"}],"key":"IUMhfGySIW"}],"key":"aj0pLeUYzH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"t3E0mQdAL8"},{"type":"outputs","id":"cmmTCft0Y58PC9s7trksJ","children":[],"key":"IWmCWQHwZe"}],"key":"RTcxaq3JKu"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"QWa9kVymh8"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"xtJe5AlK2A"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"mgl7Ta97Is"}],"key":"TMKvqihIPK"}],"key":"MqlvLsnkUe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"EJnrzthMqf"},{"type":"outputs","id":"soR-pBjX9iZguzTJciH-_","children":[],"key":"zA4QWQoCxg"}],"key":"HxoS9I1sLS"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"d5yJDe6tFz"}],"key":"yzGDK3uoPn"}],"key":"oSDOrKyyC2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"DE1ToMTIp7"},{"type":"outputs","id":"tMzi_H6OzRnEz3z11hroX","children":[],"key":"N9mrPNSIgu"}],"key":"UIkMs1SYS0"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"LBGw9W9a9J"}],"key":"B1nnYj6Rxt"}],"key":"olVxKziqzh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"bwmntOY5pT"},{"type":"outputs","id":"K9pMT3eXWlMqAPflPZt_D","children":[{