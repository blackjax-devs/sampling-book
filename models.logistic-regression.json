/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"RZWOrLJ56K"}],"key":"vyuDDy1Jxe"}],"key":"tvVDmxaAgM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"zTRKAKyla1"},{"type":"outputs","id":"GOpvCaAGuu3HolVWJLJY8","children":[],"visibility":"show","key":"NCWV1b5ZuH"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"I1kZxX4SeN"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"ui00mmCKRF"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"V9Z7qPAgi0"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"B6SxbjqDNO"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"HSzS7e27jo"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"SWfLcD8t5N"}],"key":"L1xDm4IVzF"}],"key":"aiOf4tAh19"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"sHgW7e8kmT"},{"type":"outputs","id":"WFtOePBwlMcS17relV_L2","children":[],"key":"M7YOOH48CT"}],"key":"IEIw7vYZCe"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"D6PzRJgURt"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"nScie2WwQz"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"TeX3IZx1oI"}],"key":"Vz7psoPdnj"}],"key":"uPzkVDBcQp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"nMToTS9W9k"},{"type":"outputs","id":"SgJnK5DXJb4wF9eYA3qZg","children":[],"key":"qHVWqWm5Rm"}],"key":"xSa1Uhebfj"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"Zoj0LYkbym"}],"key":"uZlXibUjOV"}],"key":"UskkRN3knI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"LzQw7AP5FJ"},{"type":"outputs","id":"UuF50yCjNQFxa0diytx2K","children":[],"key":"NW7n4IKL0T"}],"key":"GkyZYcentF"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"UtcooAHQJ8"}],"key":"KgtonBG2q3"}],"key":"DkgqcBSsxj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"bQUdKJ0JAG"},{"type":"outputs","id":"gsCBOsa--ugEhYnv7ZGUL","children":[{