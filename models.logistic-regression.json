/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"qkzyJ4HF0V"}],"key":"xZGa7kq9yF"}],"key":"MR06HCJSt8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"uYzgD3S4xS"},{"type":"outputs","id":"nu8Ew9daiDtj0GNp_Ugbi","children":[],"visibility":"show","key":"qYt8skr5TU"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"F8m0cfnOdl"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"oq1UJrPFMF"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"U7sexnwfxV"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"f0LSLWaQlw"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"fwLLjxOXq5"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"afsaEOCWt5"}],"key":"gSJH5ezOHu"}],"key":"RTSSfq2RFQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"hJLGm5j72L"},{"type":"outputs","id":"Z7ni9AGuDWrt3VYgRkblM","children":[],"key":"v80CF0NJA2"}],"key":"bnTCjKBxOd"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"UQmjese4MA"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"tx6I1KBAId"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"eIxQwLVjUE"}],"key":"jIv08txrPG"}],"key":"tFtlu9npZG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"t0Bgi4WpX5"},{"type":"outputs","id":"yMOZgj1jIM19Dv1NoEKO-","children":[],"key":"TOrDPkkRwW"}],"key":"V7k1VOby6o"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"dK28PjakEH"}],"key":"VFBznAimc0"}],"key":"nrN0gFvrpr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"ugUD4A3m2W"},{"type":"outputs","id":"F-0Ls8G9_9fylQ5ZiKMmB","children":[],"key":"vUT1pat8iu"}],"key":"zwxkHZghyQ"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"jTjbEXhWFo"}],"key":"dZDMf9PnSA"}],"key":"ImwEU7Xpvh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"ginHcoC35G"},{"type":"outputs","id":"GKYzyAhxKzReGmc4kuEru","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x200 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"2c068b19de9cf76fca68ecbda205a5ac","path":"/sampling-book/build/2c068b19de9cf76fca68ecbda205a5ac.png"}}},"key":"APksTxCr79"}],"visibility":"show","key":"QFYi76nc16"}],"data":{"tags":[]},"visibility":"show","key":"OwQpxrF7aU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\nchains = states.position[burnin:, :]\nnsamp, _ = chains.shape","key":"nmGXhYzWuW"},{"type":"outputs","id":"UrhCbeDHbuRdJS5lCSuBc","children":[],"key":"WwvDQyNb9X"}],"key":"rcOcOkytBi"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"children":[{"type":"text","value":"Predictive Distribution","position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"key":"tQYJUSpXQl"}],"identifier":"predictive-distribution","label":"Predictive Distribution","html_id":"predictive-distribution","implicit":true,"key":"s0hz0zN4MI"},{"type":"paragraph","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"children":[{"type":"text","value":"Having infered the posterior distribution of the regression’s coefficients we can compute the probability to belong to the first cluster at each position ","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"EbObBz7stw"},{"type":"inlineMath","value":"(X_0, X_1)","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><msub><mi>X</mi><mn>0</mn></msub><mo separator=\"true\">,</mo><msub><mi>X</mi><mn>1</mn></msub><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">(X_0, X_1)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">(</span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3011em;\"><span style=\"top:-2.55em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">0</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.3011em;\"><span style=\"top:-2.55em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.15em;\"><span></span></span></span></span></span></span><span class=\"mclose\">)</span></span></span></span>","key":"zg3EClbVMN"},{"type":"text","value":".","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"dIcdNB8VWc"}],"key":"ABhM0aINJs"}],"key":"Uq34GXMqfF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a meshgrid\nxmin, ymin = X.min(axis=0) - 0.1\nxmax, ymax = X.max(axis=0) + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"hxnTAMSTd7"},{"type":"outputs","id":"WkB9fQExkR0b1LtB6DvAw","children":[],"key":"zdDIA4n3DM"}],"key":"dyUVp6HFdO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\");","visibility":"hide","key":"z49ZGaCaVD"},{"type":"outputs","id":"oCNLDNCpCaSFtUXtGnzw6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"6bfe058089219d1da6c17887c33ee87f","path":"/sampling-book/build/6bfe058089219d1da6c17887c33ee87f.png"}}},"key":"BcSk9LW37P"}],"visibility":"show","key":"Edtcdlxtow"}],"data":{"tags":[]},"visibility":"show","key":"mchEG0xrQv"}],"key":"x9pJfH5D8B"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Sparse regression","url":"/models/sparse-regression","group":"Models"},"next":{"title":"Bayesian Logistic Regression With Latent Gaussian Sampler","url":"/models/logisticregressionwithlatentgaussiansampler","group":"Models"}}},"domain":"http://localhost:3000"}