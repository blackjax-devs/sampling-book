 + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"wvXmvyFNDp"},{"type":"outputs","id":"HNlcAmsZ9IU1QuG8AVGk-","children":[],"key":"rn056ZCdpl"}],"key":"YKvdhufRrE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\");","visibility":"hide","key":"iKt5da7aV3"},{"type":"outputs","id":"zc4J7UIStUaBLfn64CHlK","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"6bfe058089219d1da6c17887c33ee87f","path":"/sampling-book/build/6bfe058089219d1da6c17887c33ee87f.png"}}},"key":"fEbzkymrlF"}],"visibility":"show","key":"ueEuXJbLoH"}],"data":{"tags":[]},"visibility":"show","key":"mIPHV5D4st"}],"key":"VTggicWpzS"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Sparse regression","url":"/models/sparse-regression","group":"Models"},"next":{"title":"Bayesian Logistic Regression With Latent Gaussian Sampler","url":"/models/logisticregressionwithlatentgaussiansampler","group":"Models"}}},"domain":"http://localhost:3000"}