 + 0.1\nstep = 0.1\nXspace = jnp.mgrid[xmin:xmax:step, ymin:ymax:step]\n_, nx, ny = Xspace.shape\n\n# Compute the average probability to belong to the first cluster at each point on the meshgrid\nPhispace = jnp.concatenate([jnp.ones((1, nx, ny)), Xspace])\nZ_mcmc = sigmoid(jnp.einsum(\"mij,sm->sij\", Phispace, chains))\nZ_mcmc = Z_mcmc.mean(axis=0)","key":"lo9UEimyFn"},{"type":"outputs","id":"6VoOWxWl8sfU65-ckRXDA","children":[],"key":"rVT2tujjcF"}],"key":"vQ8t6sp43I"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.contourf(*Xspace, Z_mcmc)\nplt.scatter(*X.T, c=colors)\nplt.xlabel(r\"$X_0$\")\nplt.ylabel(r\"$X_1$\");","visibility":"hide","key":"e5FUaAKsRk"},{"type":"outputs","id":"ym18qc298UZy1OJOK4u-Q","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x800 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"6bfe058089219d1da6c17887c33ee87f","path":"/sampling-book/build/6bfe058089219d1da6c17887c33ee87f.png"}}},"key":"F6ut3oZH3e"}],"visibility":"show","key":"JIqvTfn6Nn"}],"data":{"tags":[]},"visibility":"show","key":"d5JTzfEHTt"}],"key":"lQ3ojnPuHc"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Sparse regression","url":"/models/sparse-regression","group":"Models"},"next":{"title":"Bayesian Logistic Regression With Latent Gaussian Sampler","url":"/models/logisticregressionwithlatentgaussiansampler","group":"Models"}}},"domain":"http://localhost:3000"}