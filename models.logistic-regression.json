/span><span class=\"mord\"><span class=\"mord mathnormal\" style=\"margin-right:0.07847em;\">X</span><span class=\"msupsub\"><span class=\"vlist-t vlist-t2\"><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.8247em;\"><span style=\"top:-2.4519em;margin-left:-0.0785em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mtight\">1</span></span></span><span style=\"top:-3.063em;margin-right:0.05em;\"><span class=\"pstrut\" style=\"height:2.7em;\"></span><span class=\"sizing reset-size6 size3 mtight\"><span class=\"mord mathnormal mtight\">i</span></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.2481em;\"><span></span></span></span></span></span></span><span class=\"mclose delimcenter\" style=\"top:0em;\"><span class=\"delimsizing size1\">]</span></span></span></span></span></span>","key":"qgbdgC5MzN"}],"key":"IWsRKjoVrV"}],"key":"LsJuCF39Fm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"Phi = jnp.c_[jnp.ones(num_points)[:, None], X]\nN, M = Phi.shape\n\n\ndef sigmoid(z):\n    return jnp.exp(z) / (1 + jnp.exp(z))\n\n\ndef log_sigmoid(z):\n    return z - jnp.log(1 + jnp.exp(z))\n\n\ndef logdensity_fn(w, alpha=1.0):\n    \"\"\"The log-probability density function of the posterior distribution of the model.\"\"\"\n    log_an = log_sigmoid(Phi @ w)\n    an = Phi @ w\n    log_likelihood_term = y * log_an + (1 - y) * jnp.log(1 - sigmoid(an))\n    prior_term = alpha * w @ w / 2\n\n    return -prior_term + log_likelihood_term.sum()","visibility":"show","key":"jG8LmyYF66"},{"type":"outputs","id":"kCiC4of-gFhXkB-WXT4De","children":[],"visibility":"show","key":"KSegN5mvX7"}],"data":{"tags":["hide-stderr"]},"visibility":"show","key":"BpG8ajxe2O"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"children":[{"type":"text","value":"Posterior Sampling","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"UFmDH8DHjI"}],"identifier":"posterior-sampling","label":"Posterior Sampling","html_id":"posterior-sampling","implicit":true,"key":"yDhOj69Nu1"},{"type":"paragraph","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"We use ","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"CMfeo6yx6W"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"ipgZLssNq8"},{"type":"text","value":"’s Random Walk RMH kernel to sample from the posterior distribution.","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"SnlkZTa3ry"}],"key":"V0jaxk1Tvn"}],"key":"Kie17QhemF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, init_key = jax.random.split(rng_key)\n\nw0 = jax.random.multivariate_normal(init_key, 0.1 + jnp.zeros(M), jnp.eye(M))\nrmh = blackjax.rmh(logdensity_fn, blackjax.mcmc.random_walk.normal(jnp.ones(M) * 0.05))\ninitial_state = rmh.init(w0)","key":"BsAOkFK9F1"},{"type":"outputs","id":"LWihdAXD84m8K-YzTDG1y","children":[],"key":"ZWKBnZxUSZ"}],"key":"CcqPAsDpCo"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"Since ","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"DqFHIoGkhA"},{"type":"inlineCode","value":"blackjax","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"wNr3Uu0JBt"},{"type":"text","value":" does not provide an inference loop we need to implement one ourselves:","position":{"start":{"line":124,"column":1},"end":{"line":124,"column":1}},"key":"smFgdc7jki"}],"key":"xAPnvktSes"}],"key":"dlEOBmNcTM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def inference_loop(rng_key, kernel, initial_state, num_samples):\n    @jax.jit\n    def one_step(state, rng_key):\n        state, _ = kernel(rng_key, state)\n        return state, state\n\n    keys = jax.random.split(rng_key, num_samples)\n    _, states = jax.lax.scan(one_step, initial_state, keys)\n\n    return states","key":"gVNAbwCdJ6"},{"type":"outputs","id":"FyHtjJRX9XKPT3xksLM7_","children":[],"key":"gmWOI0PnBw"}],"key":"sIRUKun4wU"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"text","value":"We can now run the inference:","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"s8qx91Rorj"}],"key":"Vok12Oqro4"}],"key":"x9oz5jsbtT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rng_key, sample_key = jax.random.split(rng_key)\nstates = inference_loop(sample_key, rmh.step, initial_state, 5_000)","key":"X3MuzPLyV7"},{"type":"outputs","id":"QUyAmAd0zFs4yz7dKh9xM","children":[],"key":"e6lK2MQMka"}],"key":"FOwMdZUBkC"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"And display the trace:","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"VCCYEoCzOu"}],"key":"rPPdxzutqm"}],"key":"dJD5CUoXvG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\n\nfig, ax = plt.subplots(1, 3, figsize=(12, 2))\nfor i, axi in enumerate(ax):\n    axi.plot(states.position[:, i])\n    axi.set_title(f\"$w_{i}$\")\n    axi.axvline(x=burnin, c=\"tab:red\")\nplt.show()","visibility":"hide","key":"qqwP7JOSRV"},{"type":"outputs","id":"Mp0bmdI93kNttg2F3Iox5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x200 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"2c068b19de9cf76fca68ecbda205a5ac","path":"/sampling-book/build/2c068b19de9cf76fca68ecbda205a5ac.png"}}},"key":"yu2YxAQGGP"}],"visibility":"show","key":"QQHTokj1tO"}],"data":{"tags":[]},"visibility":"show","key":"n0du1NxHgp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"burnin = 300\nchains = states.position[burnin:, :]\nnsamp, _ = chains.shape","key":"ZGn7AdBdrZ"},{"type":"outputs","id":"r42nnhQmqf5WnEyf-E9fG","children":[],"key":"MsjckfkTvi"}],"key":"DA0dMiHWqV"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"children":[{"type":"text","value":"Predictive Distribution","position":{"start":{"line":167,"column":1},"end":{"line":167,"column":1}},"key":"gLhu3cDC8G"}],"identifier":"predictive-distribution","label":"Predictive Distribution","html_id":"predictive-distribution","implicit":true,"key":"lFX9U6SEm3"},{"type":"paragraph","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"children":[{"type":"text","value":"Having infered the posterior distribution of the regression’s coefficients we can compute the probability to belong to the first cluster at each position ","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"GCIm5Gg4Eb"},{"type":"inlineMath","value":"(X_0, X_1)","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">(</mo><msub><mi>X</mi><mn>0</mn></msub><mo separator=\"true\">,</mo><msub><mi>X</mi><mn>1</mn></msub><mo stretchy=\"false\">)</mo></mrow><annotation e